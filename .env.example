# ─────────────────────────────────────────────────────────────
# soaviz studio — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# 1) `cp .env.example .env`
# 2) 값 채우기
# 3) production 배포 시 절대 커밋 X — .gitignore로 차단됨
# ─────────────────────────────────────────────────────────────

# ─── 앱 메타 ─────────────────────────────────────────────────
APP_ENV=development                                  # development | staging | production
APP_VERSION=0.1.0
PORT=8787

# ─── CORS ────────────────────────────────────────────────────
# production: 명시적 origin (쉼표 구분)
# 비워두면 localhost·127.0.0.1·file:// 만 허용 (개발용)
ALLOWED_ORIGINS=https://soaviz.studio,https://app.soaviz.studio

# ─── Rate Limit ──────────────────────────────────────────────
RATE_LIMIT_PER_MIN=60

# ─── 프론트엔드용 BACKEND URL (vercel env에 주입) ───────────
BACKEND_URL=https://api.soaviz.studio

# ─── BYOK 폴백 (사용자 키 없을 때 .env 사용) ────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
REPLICATE_API_TOKEN=

# ─── Supabase (Phase 1+) ─────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (Phase 2+) ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=

# ─── PortOne (한국 결제, Phase 2+) ───────────────────────────
PORTONE_API_KEY=
PORTONE_API_SECRET=

# ─── Sentry ──────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Storage (Cloudflare R2) ─────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=soaviz-studio
R2_PUBLIC_URL=https://cdn.soaviz.studio

# ─── Upstash Redis (Rate Limit 분산용) ───────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── 운영 ────────────────────────────────────────────────────
MAX_DURATION_SEC=1800
RESULT_TTL_SEC=86400
